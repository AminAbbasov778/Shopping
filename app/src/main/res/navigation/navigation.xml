<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/navigation"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.example.myshopapp.presentation.screen.SplashFragment"
        android:label="fragment_splash"
        tools:layout="@layout/fragment_splash" >
        <action
            android:id="@+id/action_splashFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_splashFragment_to_shiftFragment"
            app:destination="@id/shiftFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
    </fragment>
    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.myshopapp.presentation.screen.LoginFragment"
        android:label="LoginFragment" >
        <action
            android:id="@+id/action_loginFragment_to_shiftFragment"
            app:destination="@id/shiftFragment" />
    </fragment>
    <fragment
        android:id="@+id/shiftFragment"
        android:name="com.example.myshopapp.presentation.screen.ShiftFragment"
        android:label="ShiftFragment" />
    <fragment
        android:id="@+id/addProductFragment"
        android:name="com.example.myshopapp.presentation.screen.AddProductFragment"
        android:label="AddProductFragment" />
    <fragment
        android:id="@+id/productListFragment"
        android:name="com.example.myshopapp.presentation.screen.ProductListFragment"
        android:label="ProductListFragment" >
        <action
            android:id="@+id/action_productListFragment_to_addProductFragment"
            app:destination="@id/addProductFragment" />
    </fragment>
    <fragment
        android:id="@+id/saleFragment2"
        android:name="com.example.myshopapp.presentation.screen.SaleFragment"
        android:label="SaleFragment" >
        <action
            android:id="@+id/action_saleFragment2_to_paymentFragment"
            app:destination="@id/paymentFragment" />
    </fragment>
    <fragment
        android:id="@+id/paymentFragment"
        android:name="com.example.myshopapp.presentation.screen.PaymentFragment"
        android:label="PaymentFragment" />
    <fragment
        android:id="@+id/shiftSalesFragment"
        android:name="com.example.myshopapp.presentation.screen.ShiftSalesFragment"
        android:label="ShiftSalesFragment" />
    <fragment
        android:id="@+id/qrScannerFragment"
        android:name="com.example.myshopapp.presentation.screen.QrScannerFragment"
        android:label="fragment_qr_scanner"
        tools:layout="@layout/fragment_qr_scanner" >
        <action
            android:id="@+id/action_qrScannerFragment_to_saleDetailFragment"
            app:destination="@id/saleDetailFragment" />
    </fragment>
    <fragment
        android:id="@+id/saleDetailFragment"
        android:name="com.example.myshopapp.presentation.screen.SaleDetailFragment"
        android:label="fragment_sale_detail"
        tools:layout="@layout/fragment_sale_detail" />
    <fragment
        android:id="@+id/depositFragment"
        android:name="com.example.myshopapp.presentation.screen.DepositFragment"
        android:label="DepositFragment" />
    <fragment
        android:id="@+id/withdrawFragment"
        android:name="com.example.myshopapp.presentation.screen.WithdrawFragment"
        android:label="WithdrawFragment" />
</navigation>